{
    "name": "flutter-mirror",
    "displayName": "Flutter Mirror",
    "description": "Flutter项目的Gradle分发源替换为腾讯云镜像",
    "version": "1.2.0",
    "engines": {
        "vscode": "^1.107.0"
    },
    "publisher": "morningstart",
    "repository": "https://github.com/morning-start/flutter-mirror",
    "icon": "flutter-cn-logo-default.png",
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "flutter-mirror.replaceTencentMirror",
        "flutter-mirror.replaceLocalGradle"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "flutter-mirror.replaceTencentMirror",
                "title": "替换为腾讯云镜像源",
                "category": "Flutter Mirror"
            },
            {
                "command": "flutter-mirror.replaceLocalGradle",
                "title": "替换为本地 Gradle 文件",
                "category": "Flutter Mirror"
            }
        ],
        "configuration": {
            "title": "Flutter Mirror",
            "properties": {
                "flutterMirror.localGradlePath": {
                    "type": "string",
                    "default": "",
                    "description": "本地 Gradle 分发目录路径，例如: C:\\Users\\用户名\\.gradle。留空则使用 GRADLE_USER_HOME 环境变量或默认路径"
                },
                "flutterMirror.gradleMirrorUrl": {
                    "type": "string",
                    "default": "mirrors.cloud.tencent.com/gradle",
                    "description": "Gradle 镜像源 URL，默认为腾讯云镜像"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "bun run package",
        "compile": "bun run check-types && bun run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "bun run check-types && bun run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "bun run compile-tests && bun run compile && bun run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/vscode": "^1.107.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.14.0",
        "typescript-eslint": "^8.54.0",
        "eslint": "^9.26.0",
        "esbuild": "^0.27.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2"
    }
}
